{
  "name": "@hugo-hebert/bbucket-cli",
  "version": "0.1.0",
  "description": "Bitbucket CLI — manage branches, pull requests, pipelines, and environments from the terminal",
  "author": "Hugo Hebert",
  "license": "MIT",
  "type": "module",
  "bin": {
    "bb": "./bin/run.js"
  },
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hugo-Hbrt/bbucket-cli.git"
  },
  "homepage": "https://github.com/Hugo-Hbrt/bbucket-cli#readme",
  "bugs": {
    "url": "https://github.com/Hugo-Hbrt/bbucket-cli/issues"
  },
  "keywords": [
    "bitbucket",
    "cli",
    "pull-request",
    "pipeline",
    "deployment",
    "devops"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "tsc --noEmit",
    "check": "biome check --write .",
    "check:ci": "biome check .",
    "test": "npm run build && node --test 'test/**/*.test.js'",
    "prepublishOnly": "npm run check:ci && npm test",
    "prepack": "npm run build && oclif manifest",
    "postpack": "shx rm -f oclif.manifest.json",
    "dev": "npm run build && ./bin/run.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "@oclif/core": "^4.0.30",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/node": "^20.11.0",
    "oclif": "^4.15.0",
    "shx": "^0.3.4",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "oclif": {
    "bin": "bb",
    "dirname": "bb",
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Manage Bitbucket authentication credentials"
      },
      "branch": {
        "description": "List, filter, and delete repository branches"
      },
      "pr": {
        "description": "Manage pull requests: list, view, create, review, merge, and more"
      },
      "pipeline": {
        "description": "Trigger, inspect, and wait on Bitbucket Pipelines"
      },
      "env": {
        "description": "Manage deployment environments and their variables"
      },
      "browse": {
        "description": "Open Bitbucket pages in your default browser"
      },
      "option": {
        "description": "Manage persistent CLI preferences"
      }
    }
  }
}
